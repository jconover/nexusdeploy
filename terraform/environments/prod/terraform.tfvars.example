# Production environment — copy to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars with real credentials.

project_id              = "my-gcp-project-prod"
cloud_run_image         = "us-central1-docker.pkg.dev/my-gcp-project-prod/nexusdeploy/api:v1.0.0"
functions_source_bucket = "nexusdeploy-prod-functions-src"
alert_email             = "prod-oncall@example.com"

# Optional overrides
region        = "us-central1"
network_name  = "nexusdeploy-prod"
subnet_cidr   = "10.12.0.0/24"
pods_cidr     = "10.22.0.0/16"
services_cidr = "10.32.0.0/20"

cluster_name     = "nexusdeploy-prod"
gke_node_count   = 3
gke_machine_type = "e2-standard-4"

db_instance_name = "nexusdeploy-prod-db"
db_tier          = "db-custom-4-15360"
db_name          = "nexusdeploy"

cloud_run_service_name  = "nexusdeploy-api-prod"
cloud_run_min_instances = 2
cloud_run_max_instances = 20

vertex_region     = "us-central1"
slack_webhook_url = "https://hooks.slack.com/services/XXXX/YYYY/ZZZZ"
